{
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    { "src": "/", "dest": "/index.html" },
    { "src": "/quienes-somos", "dest": "/quienes-somos.html" },
    { "src": "/contacto", "dest": "/contacto.html" },
    { "src": "/blog", "dest": "/blog.html" },
    { "src": "/blog/post", "dest": "/blog-post.html" },
    { "src": "/design-system", "dest": "/design-system.html" },
    { "src": "/thank-you", "dest": "/thank-you.html" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/404.html", "status": 404 }
  ]
}
